{
  "CDI": {
    "fabrication": {
      "electrodeMaterial": {
        "type": "select",
        "options": [
          "Activated Carbon",
          "Carbon Aerogel",
          "Graphene",
          "Carbon Cloth",
          "CNT",
          "MXene"
        ]
      },
      "electrodeCoating": {
        "type": "text"
      },
      "electrodeArea": {
        "type": "number",
        "unit": "cm²",
        "default": 250
      },
      "electrodeThickness": {
        "type": "number",
        "unit": "mm",
        "default": 0.5
      },
      "electrodeSpacing": {
        "type": "number",
        "unit": "mm",
        "default": 0.8
      },
      "cellPairs": {
        "type": "number",
        "default": 20
      },
      "voltage": {
        "type": "number",
        "unit": "V",
        "default": 1.2
      }
    },

    "operation": {
      "feedTDS": {
        "unit": "ppm"
      },
      "conductivity": {
        "unit": "µS/cm"
      },
      "flowRate": {
        "unit": "L/min"
      },
      "pressure": {
        "unit": "bar"
      },
      "temperature": {
        "unit": "°C"
      },
      "targetTDS": {
        "unit": "ppm"
      }
    },

    "outputs": [
      "Salt Adsorption Capacity",
      "Average Salt Adsorption Rate",
      "Charge Efficiency",
      "Current Efficiency",
      "Energy Consumption",
      "Outlet TDS",
      "Recovery",
      "Pressure Drop"
    ]
  },

  "MCDI": {
    "fabrication": {
      "cationExchangeMembrane": {
        "type": "text"
      },
      "anionExchangeMembrane": {
        "type": "text"
      },
      "membraneThickness": {
        "type": "number",
        "unit": "mm"
      }
    }
  },

  "FCDI": {
    "fabrication": {
      "flowElectrodeMaterial": {
        "type": "text"
      },
      "slurryConcentration": {
        "type": "number",
        "unit": "%"
      },
      "tankVolume": {
        "type": "number",
        "unit": "L"
      },
      "pumpPower": {
        "type": "number",
        "unit": "W"
      }
    }
  },

  "EDI": {
    "fabrication": {
      "resinType": {
        "type": "text"
      },
      "resinHeight": {
        "type": "number",
        "unit": "mm"
      },
      "currentDensity": {
        "type": "number",
        "unit": "A/m²"
      },
      "stackVoltage": {
        "type": "number",
        "unit": "V"
      }
    }
  }
}